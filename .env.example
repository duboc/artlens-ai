# ArtLens AI — Environment Variables
# Copy to .env and fill in values, or run ./scripts/setup.sh to auto-configure.

# ─── Required ────────────────────────────────────────────────────────────────

# GCP project ID (used for Vertex AI, Firestore, Cloud Storage)
GOOGLE_CLOUD_PROJECT=your-project-id

# Cloud Storage bucket for images (selfies, scans, generated images)
GCS_BUCKET=your-project-id-artlens-media

# ─── Optional (have defaults) ───────────────────────────────────────────────

# Firestore database name (default: (default))
# FIRESTORE_DATABASE=(default)

# Express server port (default: 3001)
# PORT=3001

# Vertex AI model overrides
# MODEL_TEXT=gemini-3.1-flash-lite-preview
# MODEL_TEXT_FALLBACK=gemini-3-flash-preview
# MODEL_IMAGE=gemini-3.1-flash-image-preview
# MODEL_LIVE=gemini-live-2.5-flash-native-audio

# Vertex AI region overrides
# VERTEX_REGION_TEXT=global
# VERTEX_REGION_IMAGE=global
# VERTEX_REGION_LIVE=us-central1

# CORS allowed origins (comma-separated, set after first deploy)
# ALLOWED_ORIGINS=https://artlens-ai-xxxxx.run.app,http://localhost:3000

# ─── Cloud Run Deploy (used by scripts/deploy.sh only) ──────────────────────

# Cloud Run service name (default: artlens-ai)
# CLOUD_RUN_SERVICE=artlens-ai

# Cloud Run deploy region (default: us-central1)
# CLOUD_RUN_REGION=us-central1
